{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDirs": ["./", "./typechain-types"],
    "moduleResolution": "node"
  },
  "include": [
    "./hardhat.config.ts",
    "./scripts/**/*.ts",
    "./deploy/**/*.ts",
    "./test/**/*.ts",
    "./typechain-types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}
